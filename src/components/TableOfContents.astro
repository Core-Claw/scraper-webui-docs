---
/**
 * Table of Contents component with Phosphor-style icon
 * Shows the page's heading structure
 */
import TableOfContentsList from './TableOfContentsList.astro'

const { toc } = Astro.locals.starlightRoute

// Determine language for label
const currentPath = Astro.url.pathname
const isZhCn = currentPath.startsWith('/zh-cn')
const titleLabel = isZhCn ? '本页目录' : 'On this page'
---

{
	toc && toc.items && toc.items.length > 0 && (
		<starlight-toc
			data-min-h={toc.minHeadingLevel}
			data-max-h={toc.maxHeadingLevel}>
			<nav aria-labelledby="starlight__on-this-page">
				<div class="toc-header">
					<div class="toc-icon-wrapper">
						<!-- Phosphor-style list icon -->
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 256 256" fill="currentColor">
							<path d="M216,128a8,8,0,0,1-8,8H48a8,8,0,0,1,0-16H208A8,8,0,0,1,216,128ZM48,72H208a8,8,0,0,0,0-16H48a8,8,0,0,0,0,16ZM208,184H48a8,8,0,0,0,0,16H208a8,8,0,0,0,0-16Z"></path>
						</svg>
					</div>
					<span id="starlight__on-this-page" class="toc-title">{titleLabel}</span>
				</div>
				<TableOfContentsList toc={toc.items} />
			</nav>
		</starlight-toc>
	)
}
