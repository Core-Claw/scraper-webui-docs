---
/**
 * ApiPlayground — embeds a try-it-out form for one OpenAPI operation.
 *
 * Reads `public/openapi.json` at build time (no runtime spec fetch),
 * resolves `$ref` schemas, and renders:
 *
 *   - A header with method + path + summary
 *   - Optional API token field (only when `security` requires it)
 *   - Query / path parameter inputs with Required / Optional labels
 *   - A body editor area that includes:
 *       • the request body schema description
 *       • a "Required / Optional" badge
 *       • a fields table (name · type · required · description) so the
 *         user can see what to fill at a glance
 *       • a "Reset to example" button
 *   - A response panel: status badge + latency + pretty JSON
 *
 * Props:
 *   method  — HTTP method, case-insensitive
 *   path    — OpenAPI path, e.g. "/api/v2/workers/{workerId}/runs"
 *   server  — optional override of the spec's first server URL
 */
import { readFile } from 'node:fs/promises'
import path from 'node:path'

export interface Props {
    method: string
    path: string
    server?: string
}

const { method, path: opPath, server } = Astro.props
const methodUp = method.toUpperCase()

const specPath = path.join(process.cwd(), 'public', 'openapi.json')
let spec: any = null
let loadError: string | null = null
try {
    spec = JSON.parse(await readFile(specPath, 'utf8'))
} catch (err) {
    loadError = err instanceof Error ? err.message : String(err)
}

// -- $ref resolution ------------------------------------------------------
// OpenAPI specs use `$ref: "#/components/schemas/Foo"` extensively. Resolve
// these at build time so the rendered field table reflects the real schema.
function resolveRef(ref: string): any {
    if (!spec || !ref.startsWith('#/')) return null
    const parts = ref.slice(2).split('/')
    let cur: any = spec
    for (const p of parts) {
        if (cur == null) return null
        cur = cur[p]
    }
    return cur
}

function deref(node: any, seen = new Set<string>()): any {
    if (!node || typeof node !== 'object') return node
    if (node.$ref && typeof node.$ref === 'string') {
        if (seen.has(node.$ref)) return {} // break cycles
        seen.add(node.$ref)
        return deref(resolveRef(node.$ref), seen)
    }
    if (Array.isArray(node)) return node.map(n => deref(n, seen))
    const out: any = {}
    for (const k of Object.keys(node)) out[k] = deref(node[k], seen)
    return out
}

// -- Operation lookup -----------------------------------------------------
const op = spec?.paths?.[opPath]?.[methodUp.toLowerCase()] ?? null
const opResolved = deref(op)
const defaultServer =
    server || spec?.servers?.[0]?.url || 'https://openapi.coreclaw.com'

// -- Body schema + example ------------------------------------------------
function pickFirstExample(content: any): unknown | null {
    if (!content) return null
    const json = content['application/json']
    if (!json) return null
    if (json.examples) {
        const firstKey = Object.keys(json.examples)[0]
        if (firstKey) return json.examples[firstKey].value
    }
    if (json.example !== undefined) return json.example
    return null
}

function schemaTypeLabel(schema: any = {}): string {
    if (Array.isArray(schema.type)) {
        return schema.type.filter((type: string) => type !== 'null').join(' | ') || 'any'
    }
    if (Array.isArray(schema.enum)) return `enum: ${schema.enum.join(', ')}`
    if (schema.type === 'array') return `${schemaTypeLabel(schema.items || {})}[]`
    if (schema.type === 'object' || schema.properties) return 'object'
    return schema.type || schema.format || 'any'
}

function sentence(text: string): string {
    const trimmed = text.trim()
    if (!trimmed) return ''
    return /[.!?。]$/.test(trimmed) ? trimmed : `${trimmed}.`
}

function schemaConstraints(schema: any = {}): string[] {
    const parts: string[] = []
    if (schema.default !== undefined) parts.push(`default \`${schema.default}\``)
    if (schema.minimum !== undefined && schema.maximum !== undefined) {
        parts.push(`range ${schema.minimum}-${schema.maximum}`)
    } else if (schema.minimum !== undefined) {
        parts.push(`minimum ${schema.minimum}`)
    } else if (schema.maximum !== undefined) {
        parts.push(`maximum ${schema.maximum}`)
    }
    if (Array.isArray(schema.enum) && schema.enum.length) {
        parts.push(`allowed values: ${schema.enum.map((value: unknown) => `\`${value}\``).join(', ')}`)
    }
    return parts
}

function appendSchemaDetails(text: string, schema: any = {}): string {
    const constraints = schemaConstraints(schema)
    const base = sentence(text)
    if (!constraints.length) return base
    return `${base} Constraints: ${constraints.join('; ')}.`
}

function describeBodyField(name: string, schema: any = {}): string {
    if (name === 'callback_url') {
        return 'Callback URL. When provided, CoreClaw sends a POST request after the run status changes or finishes.'
    }
    if (name === 'input') {
        return 'Worker input payload. Read this Worker\'s input schema first; fields differ by Worker.'
    }
    if (name === 'is_async') {
        return '`true` submits asynchronously and does not wait for execution results; `false` waits for the run to finish. Defaults to `true`.'
    }
    if (name === 'limit') {
        return appendSchemaDetails(schema.description || 'Result limit for synchronous runs or reruns.', schema)
    }
    if (name === 'offset') {
        return appendSchemaDetails(schema.description || 'Result offset for synchronous runs or reruns.', schema)
    }
    if (name === 'version') {
        return appendSchemaDetails('Worker version. Use a concrete available version, or `latest` when supported by the service.', schema)
    }
    return appendSchemaDetails(schema.description || '-', schema)
}

function describeParam(param: any): string {
    const schema = param.schema || {}
    const name = param.name
    if (name === 'workerId') {
        return 'Worker slug or path. Encode `owner/name` as `owner~name` for path values.'
    }
    if (name === 'worker_id') {
        return 'Worker slug or path. Encode `owner/name` as `owner~name` for query values.'
    }
    if (name === 'runId') {
        return 'Run slug returned as `data.run_slug` from start or rerun responses.'
    }
    if (name === 'workerTaskId') {
        return 'Saved Worker task template slug.'
    }
    if (name === 'offset') return appendSchemaDetails('Pagination offset, starting from 0.', schema)
    if (name === 'limit') return appendSchemaDetails('Page size.', schema)
    if (name === 'format') return appendSchemaDetails('Export format.', schema)
    if (name === 'filter_keys') {
        return 'Comma-separated field keys used to limit exported fields, for example `title,address`.'
    }
    if (name === 'status') return appendSchemaDetails('Run status filter.', schema)
    return appendSchemaDetails(param.description || schema.description || '-', schema)
}

function parameterMeta(param: any): string {
    const parts = [param.in]
    const type = schemaTypeLabel(param.schema || {})
    if (type) parts.push(type)
    const constraints = schemaConstraints(param.schema || {})
    if (constraints.length) parts.push(constraints.join('; '))
    return parts.join(' · ')
}

function sampleSchemaValue(name: string, schema: any = {}): unknown {
    if (schema.example !== undefined) return schema.example
    if (schema.default !== undefined) return schema.default
    if (Array.isArray(schema.examples) && schema.examples.length) return schema.examples[0]
    if (Array.isArray(schema.enum) && schema.enum.length) return schema.enum[0]
    if (name === 'callback_url') return 'https://client.example.com/openapi/callback'
    if (name === 'input') return { keyword: 'coffee', limit: 10 }
    if (name === 'version') return 'latest'
    if (name === 'is_async') return true
    if (name === 'limit') return 20
    if (name === 'offset') return 0

    const type = Array.isArray(schema.type)
        ? schema.type.find((item: string) => item !== 'null')
        : schema.type

    if (type === 'object' || schema.properties) {
        const out: Record<string, unknown> = {}
        for (const [childName, childSchema] of Object.entries(schema.properties || {})) {
            out[childName] = sampleSchemaValue(childName, childSchema)
        }
        return out
    }
    if (type === 'array') return []
    if (type === 'boolean') return true
    if (type === 'integer' || type === 'number') return schema.minimum ?? 0
    if (schema.format === 'uri') return 'https://client.example.com/openapi/callback'
    return `YOUR_${String(name || 'VALUE').replace(/([a-z])([A-Z])/g, '$1_$2').toUpperCase()}`
}

function exampleFromSchema(schema: any): unknown | null {
    if (!schema) return null
    return sampleSchemaValue('', schema)
}

const bodyContent =
    opResolved?.requestBody?.content?.['application/json'] ?? null
const bodySchema = bodyContent?.schema ?? null
const bodyRequired = !!opResolved?.requestBody?.required
const bodyDescription = (
    opResolved?.requestBody?.description ||
    bodySchema?.description ||
    ''
).trim()
const exampleBody =
    pickFirstExample(opResolved?.requestBody?.content) ?? exampleFromSchema(bodySchema)
const exampleBodyStr =
    exampleBody !== null ? JSON.stringify(exampleBody, null, 2) : ''

// -- Parameters -----------------------------------------------------------
const parameters: any[] = (opResolved?.parameters || []).filter(
    (p: any) => p.in === 'query' || p.in === 'path'
)

// "Trivial body" = the spec says you can send `{}` or nothing.
// Schema is an empty object with no properties, and any provided example
// is itself empty. We hide the textarea in this case — making the user
// stare at a literal `{}` adds no value and creates the false impression
// that they need to fill something in.
function isEmptyExample(v: unknown): boolean {
    if (v === null || v === undefined) return true
    if (typeof v !== 'object') return false
    if (Array.isArray(v)) return v.length === 0
    return Object.keys(v as Record<string, unknown>).length === 0
}
const hasProperties =
    bodySchema?.type === 'object' &&
    bodySchema?.properties &&
    Object.keys(bodySchema.properties).length > 0
const isTrivialBody =
    !!bodyContent && !hasProperties && isEmptyExample(exampleBody)
const noRequestBodyMessage = parameters.length
    ? 'No JSON request body. Fill the path or query parameters above.'
    : 'No JSON request body is defined for this operation.'

// Walk the top-level body schema to expose a flat "fields" table.
type Field = {
    name: string
    type: string
    required: boolean
    description: string
}
function flattenTopLevelFields(schema: any): Field[] {
    if (!schema || schema.type !== 'object') return []
    const props = schema.properties || {}
    const required = new Set<string>(schema.required || [])
    return Object.keys(props).map(name => {
        const p = props[name] || {}
        return {
            name,
            type: schemaTypeLabel(p),
            required: required.has(name),
            description: describeBodyField(name, p),
        }
    })
}
const bodyFields = flattenTopLevelFields(bodySchema)

function sampleParamValue(param: any): string {
    if (param.schema?.default !== undefined) return String(param.schema.default)
    if (param.example !== undefined) return String(param.example)
    if (param.in !== 'path') return ''
    if (param.name === 'workerId') return 'YOUR_WORKER_ID'
    if (param.name === 'workerTaskId') return 'YOUR_WORKER_TASK_ID'
    if (param.name === 'runId') return 'YOUR_RUN_ID'
    return `YOUR_${String(param.name).replace(/([a-z])([A-Z])/g, '$1_$2').toUpperCase()}`
}

// -- Auth -----------------------------------------------------------------
const needsToken =
    Array.isArray(opResolved?.security) &&
    opResolved.security.length > 0 &&
    !opResolved.security.every((s: any) => Object.keys(s).length === 0)

// Stable id so multiple playgrounds on the same page don't collide
const id = `api-playground-${methodUp.toLowerCase()}-${opPath
    .replace(/[^a-z0-9]+/gi, '-')
    .replace(/(^-|-$)/g, '')}`
---

{loadError ? (
    <div class="api-playground api-playground--error">
        <strong>Playground unavailable:</strong> {loadError}
    </div>
) : !op ? (
    <div class="api-playground api-playground--error">
        <strong>Playground unavailable:</strong> operation <code>{methodUp} {opPath}</code> not found in <code>openapi.json</code>.
    </div>
) : (
    <api-playground
        class="api-playground"
        id={id}
        data-method={methodUp}
        data-path={opPath}
        data-server={defaultServer}
        data-needs-token={needsToken ? 'true' : 'false'}
        data-example-body={exampleBodyStr}>
        <div class="ap-head">
            <span class={`ap-method ap-method--${methodUp.toLowerCase()}`}>{methodUp}</span>
            <code class="ap-path">{opPath}</code>
            {opResolved.summary && <span class="ap-summary">{opResolved.summary}</span>}
        </div>

        <div class="ap-body">
            {needsToken ? (
                <div class="ap-section">
                    <div class="ap-section-title">
                        <span>Authentication</span>
                        <span class="ap-pill ap-pill--required">Required</span>
                    </div>
                    <div class="ap-field">
                        <div class="ap-label-row">
                            <label class="ap-label" for={`${id}-auth-mode`}>Auth mode</label>
                        </div>
                        <select
                            id={`${id}-auth-mode`}
                            class="ap-select"
                            data-role="auth-mode">
                            <option value="bearer">Authorization: Bearer</option>
                            <option value="api-key">api-key header</option>
                            <option value="query-token">Query token</option>
                        </select>
                    </div>
                    <div class="ap-field">
                        <div class="ap-label-row">
                            <label class="ap-label" for={`${id}-key`}>API token</label>
                        </div>
                        <input
                            id={`${id}-key`}
                            type="password"
                            class="ap-input"
                            autocomplete="off"
                            spellcheck="false"
                            data-role="api-token"
                            placeholder="Paste your API key"
                        />
                        <p class="ap-hint">Stored only in this browser tab. Sent only to <code>{defaultServer}</code>.</p>
                    </div>
                </div>
            ) : (
                <div class="ap-section">
                    <div class="ap-section-title">
                        <span>Authorization</span>
                        <span class="ap-pill ap-pill--optional">Not required</span>
                    </div>
                    <p class="ap-section-desc">This is a public endpoint and does not require an API token.</p>
                </div>
            )}

            {parameters.length > 0 && (
                <div class="ap-section">
                    <div class="ap-section-title">Parameters</div>
                    {parameters.map((param: any) => (
                        <div class="ap-field">
                            <div class="ap-label-row">
                                <label class="ap-label" for={`${id}-p-${param.name}`}>{param.name}</label>
                                <span class="ap-pill-meta">{parameterMeta(param)}</span>
                                <span class={`ap-pill ${param.required ? 'ap-pill--required' : 'ap-pill--optional'}`}>
                                    {param.required ? 'Required' : 'Optional'}
                                </span>
                            </div>
                            <input
                                id={`${id}-p-${param.name}`}
                                type="text"
                                class="ap-input"
                                spellcheck="false"
                                data-role="param"
                                data-param-name={param.name}
                                data-param-in={param.in}
                                placeholder={param.example ?? param.schema?.default ?? param.description ?? ''}
                                value={sampleParamValue(param)}
                            />
                            <p class="ap-hint">{describeParam(param)}</p>
                        </div>
                    ))}
                </div>
            )}

            {!bodyContent && !exampleBodyStr && (
                <div class="ap-section">
                    <div class="ap-section-title">
                        <span>Request Body</span>
                        <span class="ap-pill ap-pill--na">Not applicable</span>
                    </div>
                    <div class="ap-body-empty">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 16v-4"/>
                            <path d="M12 8h.01"/>
                        </svg>
                        <span>{noRequestBodyMessage}</span>
                    </div>
                </div>
            )}

            {(bodyContent || exampleBodyStr) && (
                isTrivialBody ? (
                    <div class="ap-section">
                        <div class="ap-section-title">
                            <span>Request Body</span>
                            <span class={`ap-pill ${bodyRequired ? 'ap-pill--required' : 'ap-pill--na'}`}>
                                {bodyRequired ? 'Required' : 'Not applicable'}
                            </span>
                        </div>
                        <div class="ap-body-empty">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M12 16v-4"/>
                                <path d="M12 8h.01"/>
                            </svg>
                            <span>
                                {bodyRequired ? 'Send an empty JSON object (`{}`).' : noRequestBodyMessage}
                                {bodyDescription && <em class="ap-body-empty-spec"> Spec: <code>{bodyDescription}</code></em>}
                            </span>
                        </div>
                    </div>
                ) : (
                    <div class="ap-section">
                        <div class="ap-section-title">
                            <span>Request Body</span>
                            <span class={`ap-pill ${bodyRequired ? 'ap-pill--required' : 'ap-pill--optional'}`}>
                                {bodyRequired ? 'Required' : 'Optional'}
                            </span>
                            <span class="ap-section-format">application/json</span>
                        </div>

                        {bodyDescription && <p class="ap-section-desc">{bodyDescription}</p>}

                        {bodyFields.length > 0 && (
                            <div class="ap-fields">
                                <div class="ap-fields-row ap-fields-head">
                                    <span>Field</span>
                                    <span>Type</span>
                                    <span>Required</span>
                                    <span>Description</span>
                                </div>
                                {bodyFields.map(f => (
                                    <div class="ap-fields-row">
                                        <code class="ap-fields-name">{f.name}</code>
                                        <span class="ap-fields-type">{f.type}</span>
                                        <span class={f.required ? 'ap-fields-req' : 'ap-fields-opt'}>
                                            {f.required ? 'Required' : 'Optional'}
                                        </span>
                                        <span class="ap-fields-desc">{f.description}</span>
                                    </div>
                                ))}
                            </div>
                        )}

                        <div class="ap-body-editor-head">
                            <span class="ap-body-editor-title">Request body (JSON)</span>
                            {exampleBodyStr && (
                                <button type="button" class="ap-link-btn" data-role="reset-example">Reset to example</button>
                            )}
                        </div>
                        <textarea
                            class="ap-textarea"
                            rows="10"
                            spellcheck="false"
                            data-role="body"
                            placeholder={bodyRequired ? '{ ... }' : 'Optional — leave empty or send {}'}>{exampleBodyStr}</textarea>
                    </div>
                )
            )}

            <div class="ap-actions">
                <button type="button" class="ap-send" data-role="send">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polygon points="6 3 20 12 6 21 6 3"/>
                    </svg>
                    Send Request
                </button>
                <button type="button" class="ap-reset-all" data-role="reset-all">Clear all</button>
            </div>

            <div class="ap-response" data-role="response" hidden>
                <div class="ap-response-head">
                    <span class="ap-status" data-role="status"></span>
                    <span class="ap-latency" data-role="latency"></span>
                </div>
                <pre class="ap-response-body"><code data-role="response-body"></code></pre>
            </div>
        </div>
    </api-playground>
)}

<script>
    class ApiPlayground extends HTMLElement {
        connectedCallback() {
            const send = this.querySelector<HTMLButtonElement>('[data-role="send"]')
            const resetExample = this.querySelector<HTMLButtonElement>('[data-role="reset-example"]')
            const resetAll = this.querySelector<HTMLButtonElement>('[data-role="reset-all"]')
            const tokenInput = this.querySelector<HTMLInputElement>('[data-role="api-token"]')
            const authMode = this.querySelector<HTMLSelectElement>('[data-role="auth-mode"]')
            const bodyEl = this.querySelector<HTMLTextAreaElement>('[data-role="body"]')
            const exampleBody = this.dataset.exampleBody || ''

            // Persist token per-tab so users don't re-paste between operations.
            if (tokenInput) {
                const stored = sessionStorage.getItem('coreclaw-doc-api-token')
                if (stored) tokenInput.value = stored
                tokenInput.addEventListener('input', () => {
                    sessionStorage.setItem(
                        'coreclaw-doc-api-token',
                        tokenInput.value
                    )
                })
            }

            const paramEls = Array.from(
                this.querySelectorAll<HTMLInputElement>('[data-role="param"]')
            )
            const initialParams = paramEls.map(el => el.value)

            send?.addEventListener('click', () => this.sendRequest())

            resetExample?.addEventListener('click', () => {
                if (bodyEl && exampleBody) bodyEl.value = exampleBody
            })

            resetAll?.addEventListener('click', () => {
                if (bodyEl) bodyEl.value = exampleBody
                if (authMode) authMode.value = 'bearer'
                paramEls.forEach((el, i) => (el.value = initialParams[i]))
                this.hideResponse()
            })
        }

        async sendRequest() {
            const method = this.dataset.method!
            const opPath = this.dataset.path!
            const server = this.dataset.server!
            const needsToken = this.dataset.needsToken === 'true'

            const tokenInput = this.querySelector<HTMLInputElement>('[data-role="api-token"]')
            const authModeEl = this.querySelector<HTMLSelectElement>('[data-role="auth-mode"]')
            const bodyEl = this.querySelector<HTMLTextAreaElement>('[data-role="body"]')
            const send = this.querySelector<HTMLButtonElement>('[data-role="send"]')

            // Build URL — substitute path params, append query params.
            let url = opPath
            const queryPairs: string[] = []
            this.querySelectorAll<HTMLInputElement>('[data-role="param"]').forEach(el => {
                const name = el.dataset.paramName!
                const where = el.dataset.paramIn!
                const value = el.value.trim()
                if (!value) return
                if (where === 'path') {
                    url = url.replace(`{${name}}`, encodeURIComponent(value))
                } else {
                    queryPairs.push(
                        `${encodeURIComponent(name)}=${encodeURIComponent(value)}`
                    )
                }
            })
            if (/\{[^}]+\}/.test(url)) {
                this.showResponse(
                    '400',
                    'Missing path parameter',
                    'Fill every required path parameter before sending the request.',
                    0
                )
                return
            }
            const token = tokenInput?.value.trim() || ''
            const authMode = authModeEl?.value || 'bearer'
            if (needsToken && authMode === 'query-token' && token) {
                queryPairs.push(`token=${encodeURIComponent(token)}`)
            }
            if (queryPairs.length) url += `?${queryPairs.join('&')}`

            // Headers
            const headers: Record<string, string> = {
                'content-type': 'application/json',
            }
            if (needsToken && token && authMode === 'bearer') {
                headers['Authorization'] = `Bearer ${token}`
            } else if (needsToken && token && authMode === 'api-key') {
                headers['api-key'] = token
            }

            // Body — only re-stringify if user actually typed something
            let body: string | undefined
            if (bodyEl && bodyEl.value.trim()) {
                try {
                    body = JSON.stringify(JSON.parse(bodyEl.value))
                } catch (err) {
                    this.showResponse(
                        '400',
                        'Invalid JSON in request body',
                        err instanceof Error ? err.message : String(err),
                        0
                    )
                    return
                }
            }

            send && (send.disabled = true)
            const t0 = performance.now()
            try {
                const res = await fetch(server.replace(/\/$/, '') + url, {
                    method,
                    headers,
                    body: method === 'GET' || method === 'HEAD' ? undefined : body,
                    mode: 'cors',
                })
                const ms = Math.round(performance.now() - t0)
                const text = await res.text()
                let pretty = text
                try {
                    pretty = JSON.stringify(JSON.parse(text), null, 2)
                } catch {
                    /* keep non-JSON as-is */
                }
                this.showResponse(String(res.status), res.statusText, pretty, ms)
            } catch (err) {
                const ms = Math.round(performance.now() - t0)
                this.showResponse(
                    'ERR',
                    'Network error',
                    err instanceof Error ? err.message : String(err),
                    ms
                )
            } finally {
                send && (send.disabled = false)
            }
        }

        showResponse(status: string, statusText: string, body: string, ms: number) {
            const wrap = this.querySelector<HTMLDivElement>('[data-role="response"]')!
            const statusEl = this.querySelector<HTMLSpanElement>('[data-role="status"]')!
            const latencyEl = this.querySelector<HTMLSpanElement>('[data-role="latency"]')!
            const bodyEl = this.querySelector<HTMLElement>('[data-role="response-body"]')!

            wrap.removeAttribute('hidden')
            statusEl.textContent = `${status} ${statusText}`.trim()
            statusEl.className = 'ap-status'
            const code = parseInt(status, 10)
            if (code >= 200 && code < 300) statusEl.classList.add('is-ok')
            else if (code >= 400) statusEl.classList.add('is-err')
            else statusEl.classList.add('is-warn')
            latencyEl.textContent = ms ? `${ms} ms` : ''
            bodyEl.textContent = body
        }

        hideResponse() {
            const wrap = this.querySelector<HTMLDivElement>('[data-role="response"]')!
            wrap.setAttribute('hidden', '')
        }
    }

    if (!customElements.get('api-playground')) {
        customElements.define('api-playground', ApiPlayground)
    }
</script>

