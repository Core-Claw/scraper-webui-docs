---
const { toc, isMobile = false, depth = 0 } = Astro.props
---

<ul class:list={{ isMobile, 'toc-list': true }}>
	{
		toc.map(heading => (
			<li>
				<a href={'#' + heading.slug}>
					<span>{heading.text}</span>
				</a>
				{heading.children.length > 0 && (
					<Astro.self
						toc={heading.children}
						depth={depth + 1}
						isMobile={isMobile}
					/>
				)}
			</li>
		))
	}
</ul>

<style define:vars={{ depth }}>
	.toc-list {
		padding: 0;
		list-style: none;
		margin: 0;
	}

	.toc-list li {
		position: relative;
	}

	a {
		--pad-inline: 0.5rem;
		display: block;
		border-radius: 4px;
		padding-block: 0.375rem;
		padding-inline: calc(0.5rem * var(--depth) + var(--pad-inline)) var(--pad-inline);
		line-height: 1.5;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		transition: all 0.2s ease;
		position: relative;
	}

	a::before {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		width: 3px;
		height: 0;
		background: hsl(var(--cafe-primary-hsl));
		border-radius: 2px;
		transition: height 0.2s ease;
	}

	a:hover {
		color: hsl(var(--cafe-primary-hsl));
		background-color: hsla(var(--cafe-primary-hsl), 0.06);
		padding-left: calc(0.5rem * var(--depth) + 1rem);
	}

	a:hover::before {
		height: 60%;
	}

	a[aria-current='true'] {
		color: hsl(var(--cafe-primary-hsl));
		font-weight: 500;
		background-color: hsla(var(--cafe-primary-hsl), 0.1);
		padding-left: calc(0.5rem * var(--depth) + 1rem);
	}

	a[aria-current='true']::before {
		height: 70%;
		background: linear-gradient(180deg, var(--cafe-gradient-1), var(--cafe-gradient-2));
	}

	/* Dark mode */
	:global(:root[data-theme='dark']) a {
		color: var(--sl-color-gray-3);
	}

	:global(:root[data-theme='dark']) a:hover {
		color: hsl(var(--cafe-primary-hsl));
		background-color: hsla(var(--cafe-primary-hsl), 0.1);
	}

	:global(:root[data-theme='dark']) a[aria-current='true'] {
		background-color: hsla(var(--cafe-primary-hsl), 0.15);
	}

	/* Nested items */
	.toc-list .toc-list {
		margin-top: 0;
	}

	/* Mobile styles */
	.isMobile a {
		--pad-inline: 1rem;
		display: flex;
		justify-content: space-between;
		gap: var(--pad-inline);
		border-top: 1px solid var(--sl-color-gray-6);
		border-radius: 0;
		padding-block: 0.5rem;
		color: var(--sl-color-text);
		font-size: var(--sl-text-sm);
		text-decoration: none;
		outline-offset: var(--sl-outline-offset-inside);
	}

	.isMobile a::before {
		display: none;
	}

	.isMobile:first-child > li:first-child > a {
		border-top: 0;
	}

	.isMobile a[aria-current='true'],
	.isMobile a[aria-current='true']:hover,
	.isMobile a[aria-current='true']:focus {
		color: var(--sl-color-white);
		background-color: unset;
	}

	.isMobile a[aria-current='true']::after {
		content: '';
		width: 1rem;
		background-color: var(--sl-color-text-accent);
		/* Check mark SVG icon */
		-webkit-mask-image: url('data:image/svg+xml;base64,');
		mask-image: url('data:image/svg+xml;base64,');
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		flex-shrink: 0;
	}
</style>
